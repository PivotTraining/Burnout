# BurnoutIQ environment variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (enterprise dashboard auth + storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — consumer ladder Prices
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# BurnoutIQ Pro — one-time, $19
STRIPE_PRICE_PRO=

# BurnoutIQ Continuum — monthly recurring, $9/mo and $79/yr
STRIPE_PRICE_CONTINUUM_MONTHLY=
STRIPE_PRICE_CONTINUUM_ANNUAL=

# BurnoutIQ Coach — one-time, $197
STRIPE_PRICE_COACH=

# Legacy enterprise Subscription Price (per-employee/yr seat-based)
STRIPE_PRICE_SUBSCRIPTION_BASE=

# Resend (transactional email: results, whitepaper, briefing, nudges)
RESEND_API_KEY=
# IMPORTANT: FROM domain must be VERIFIED in Resend.
# burnoutiqtest.com is verified; pivottraining.us is NOT.
RESEND_FROM_EMAIL="BurnoutIQ <hello@burnoutiqtest.com>"
RESEND_NOTIFY_EMAIL=hello@pivottraining.us
# Resend Audience for lead capture (assessment + webinar registrants).
RESEND_AUDIENCE_ID=

# Console gating (when Supabase isn't yet provisioned, you can still
# show the dashboard to a sales prospect via a shared password).
# When unset AND Supabase isn't configured, /dashboard is hidden (404).
DASHBOARD_DEMO_PASSWORD=

# Internal ops token for /api/orgs/provision and /admin/provision.
# Generate with: openssl rand -base64 32
ADMIN_TOKEN=

# Whitepaper PDF (publicly hosted asset URL)
WHITEPAPER_PDF_URL=https://example.com/six-archetypes-of-burnout.pdf

# Calendly (briefing booking + Coach 1:1 booking)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/pivot-training/consultation-calendar
NEXT_PUBLIC_CALENDLY_COACH_URL=https://calendly.com/pivot-training/burnoutiq-coach

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Social Media Agent
# Anthropic API key for the post generator (uses claude-opus-4-7).
ANTHROPIC_API_KEY=

# X (Twitter) API v2 — OAuth 2.0 user-context bearer with
# tweet.write + media.write scopes (and tweet.read + users.read if you
# also want the listening loop). X_USER_ID is the numeric ID of the
# account the agent posts as; required to fetch mentions.
X_BEARER_TOKEN=
X_USER_ID=

# LinkedIn — access token with w_organization_social, plus the org URN
# in the form urn:li:organization:12345678.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Facebook — Page ID + long-lived Page access token (pages_manage_posts).
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
